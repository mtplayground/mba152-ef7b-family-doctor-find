# PostgreSQL connection used by sqlx. Set this from the Ideavibes managed database.
DATABASE_URL=postgres://app_user:app_password@localhost:5432/family_doctor_find

# Backend bind address. The deployed app should listen on 0.0.0.0:8080.
BIND_ADDRESS=0.0.0.0:8080

# Public origin accepted by future same-origin/CORS checks.
ALLOWED_CORS_ORIGIN=http://localhost:5173

# OpenStreetMap tile template used by the frontend map view.
OSM_TILE_URL_TEMPLATE=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# OpenStreetMap Nominatim endpoint and user agent used by backend geocoding.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=family-doctor-finder/0.1

# Anonymous submission rate-limit defaults.
RATE_LIMIT_WINDOW_SECS=60
RATE_LIMIT_MAX_REQUESTS=30
REPORT_REPEAT_WINDOW_SECS=3600
REPORT_REPEAT_MAX_REQUESTS=1
