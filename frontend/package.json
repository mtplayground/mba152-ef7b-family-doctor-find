    "autoprefixer": "^10.5.4",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "postcss": "^8.5.20",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.19",
